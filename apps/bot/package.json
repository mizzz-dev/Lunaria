{
  "name": "@lunaria/bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm --filter @lunaria/core build && pnpm --filter @lunaria/db build && tsx watch src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run src"
  },
  "dependencies": {
    "@lunaria/core": "workspace:*",
    "@lunaria/db": "workspace:*",
    "@lunaria/shared": "workspace:*",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  }
}
