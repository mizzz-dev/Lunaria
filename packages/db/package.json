{
  "name": "@lunaria/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy --schema prisma/schema.prisma",
    "db:dev": "dotenv -e ../../.env -- prisma migrate dev --schema prisma/schema.prisma",
    "db:generate": "dotenv -e ../../.env -- prisma generate --schema prisma/schema.prisma",
    "db:studio": "dotenv -e ../../.env -- prisma studio --schema prisma/schema.prisma",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run src"
  },
  "dependencies": {
    "@lunaria/core": "workspace:*",
    "@prisma/client": "6.19.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "6.19.0"
  }
}
